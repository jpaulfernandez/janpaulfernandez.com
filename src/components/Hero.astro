---
interface Props {
  greeting: string;
  intro: string;
  ctaPrimaryLabel?: string;
  ctaSecondaryLabel?: string;
  /** Plain-text snippet of the latest Now entry, shown as a one-liner. */
  nowSnippet?: string;
}

const { greeting, intro } = Astro.props;
---

<section class="md:py-16 bg-magenta-900 md:bg-transparent">
  <div class="max-w-[1140px] mx-auto px-0 md:px-6">
    <div class="bg-magenta-900 text-beige-100 rounded-none md:rounded-[2.5rem] px-6 pt-16 pb-12 sm:px-10 sm:py-14 md:p-20 md:shadow-2xl relative overflow-hidden border-0 md:border md:border-magenta-800/40">
      <div class="max-w-[980px] flex flex-col gap-8 md:gap-10 relative z-10 fade-rise">
        <h1 class="font-display text-hero-title text-beige-50 tracking-tight leading-none">
          {greeting}
        </h1>
        <p class="text-hero-intro font-normal text-beige-100/90 leading-relaxed max-w-[52ch] md:max-w-[60ch]">
          {intro}
        </p>

        <div class="flex flex-col sm:flex-row flex-wrap gap-5 sm:gap-10 pt-8 border-t border-beige-100/20">
          <a
            href="/work-with-me#contact"
            class="group inline-flex items-center gap-2 text-body font-bold text-beige-50 hover:text-citrus-300 no-underline transition-colors focus:outline-none focus:ring-2 focus:ring-citrus-300 rounded"
          >
            <span>Invite me to coffee</span>
            <span class="text-citrus-300 group-hover:translate-x-1.5 transition-transform duration-200">→</span>
          </a>
          <a
            href="/thoughts"
            class="group inline-flex items-center gap-2 text-body font-bold text-beige-50 hover:text-citrus-300 no-underline transition-colors focus:outline-none focus:ring-2 focus:ring-citrus-300 rounded"
          >
            <span>Overthinkings and Brain dumps</span>
            <span class="text-citrus-300 group-hover:translate-x-1.5 transition-transform duration-200">→</span>
          </a>
          <a
            href="/now"
            class="group inline-flex items-center gap-2 text-body font-bold text-beige-50 hover:text-citrus-300 no-underline transition-colors focus:outline-none focus:ring-2 focus:ring-citrus-300 rounded"
          >
            <span>See what I'm doing now</span>
            <span class="text-citrus-300 group-hover:translate-x-1.5 transition-transform duration-200">→</span>
          </a>
        </div>
      </div>
    </div>
  </div>
</section>
