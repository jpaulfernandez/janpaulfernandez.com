---
/**
 * Stacking service cards: each card sticks below the nav as you scroll,
 * so the next one slides up over it. Pure CSS (position: sticky), no JS.
 */
interface Service {
  title: string;
  description: string;
  icon?: string;
}

interface Props {
  services: Service[];
}

const { services } = Astro.props;

// One palette per stack position — keeps colors deliberate, not per-content.
const palettes = [
  {
    card: 'bg-dark-plum-900 text-beige-100',
    kicker: 'text-action-lemon-light',
    title: 'text-beige-100',
    body: 'text-beige-100/90',
    art: 'text-action-lemon-light',
  },
  {
    card: 'bg-alert-lavender-200 text-ink',
    kicker: 'text-dark-plum-900',
    title: 'text-dark-plum-900',
    body: 'text-ink',
    art: 'text-dark-plum-900',
  },
  {
    card: 'bg-alert-light-blue-100 text-ink border border-ink/10',
    kicker: 'text-alert-terracotta-600',
    title: 'text-ink',
    body: 'text-ink',
    art: 'text-alert-terracotta-600',
  },
];
---

<div class="flex flex-col gap-6">
  {services.map((service, i) => {
    const palette = palettes[i % palettes.length];
    return (
      <article
        class={`sticky rounded-3xl p-8 md:p-12 shadow-lg ${palette.card}`}
        style={`top: calc(5.5rem + ${i * 1.75}rem);`}
      >
        <div class="flex flex-col md:flex-row md:items-center gap-8 md:gap-12">
          <div class="flex-1 flex flex-col gap-3">
            <p class={`m-0 text-small font-bold uppercase tracking-wider ${palette.kicker}`}>
              0{i + 1}
            </p>
            <h3 class={`m-0 font-display text-h2 leading-tight ${palette.title}`}>
              {service.title}
            </h3>
            <p class={`m-0 text-body leading-relaxed max-w-[52ch] ${palette.body}`}>
              {service.description}
            </p>
          </div>

          <div class={`shrink-0 w-28 md:w-44 self-end md:self-center ${palette.art}`} aria-hidden="true">
            {service.icon === 'talks' ? (
              /* Talks & workshops: speech bubble with a spark */
              <svg viewBox="0 0 96 96" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M16 24 h56 a8 8 0 0 1 8 8 v28 a8 8 0 0 1-8 8 H44 l-14 14 v-14 H16 a8 8 0 0 1-8-8 V32 a8 8 0 0 1 8-8 Z" stroke="currentColor" stroke-width="4" stroke-linejoin="round"/>
                <path d="M44 32 l4 10 10 4-10 4-4 10-4-10-10-4 10-4 Z" fill="#E8A13C"/>
                <path d="M62 40 h8 M62 50 h12" stroke="currentColor" stroke-width="4" stroke-linecap="round"/>
              </svg>
            ) : service.icon === 'translate' ? (
              /* Fractional product owner: idea to code, translated */
              <svg viewBox="0 0 96 96" fill="none" xmlns="http://www.w3.org/2000/svg">
                <circle cx="24" cy="30" r="14" stroke="currentColor" stroke-width="4"/>
                <circle cx="24" cy="30" r="5" fill="#E8A13C"/>
                <path d="M58 22 l-8 8 8 8 M74 22 l8 8-8 8" stroke="currentColor" stroke-width="4" stroke-linecap="round" stroke-linejoin="round"/>
                <path d="M30 62 h36 m0 0-8-8 m8 8-8 8" stroke="currentColor" stroke-width="4" stroke-linecap="round" stroke-linejoin="round"/>
                <path d="M66 78 H30 m0 0 8-8 m-8 8 8 8" stroke="currentColor" stroke-width="4" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            ) : (
              /* Product consultation: compass over a route */
              <svg viewBox="0 0 96 96" fill="none" xmlns="http://www.w3.org/2000/svg">
                <circle cx="48" cy="44" r="28" stroke="currentColor" stroke-width="4"/>
                <path d="M60 32 52 52l-16 8 8-20 Z" stroke="currentColor" stroke-width="4" stroke-linejoin="round"/>
                <circle cx="48" cy="44" r="4" fill="#E8A13C"/>
                <path d="M14 84 c14-10 20 6 34 0 s20 6 34 0" stroke="currentColor" stroke-width="4" stroke-linecap="round"/>
              </svg>
            )}
          </div>
        </div>
      </article>
    );
  })}
</div>
