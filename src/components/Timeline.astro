---
import { render } from 'astro:content';
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';

interface Props {
  entries: CollectionEntry<'career'>[];
  variant?: 'compact' | 'full';
  sortOrder?: 'asc' | 'desc';
}

const { entries, variant = 'compact', sortOrder = 'desc' } = Astro.props;

// Sort entries by order (desc = latest first, asc = oldest first)
const sortedEntries = [...entries].sort((a, b) => 
  sortOrder === 'desc' ? b.data.order - a.data.order : a.data.order - b.data.order
);

const processedEntries = await Promise.all(
  sortedEntries.map(async (entry) => {
    const { Content } = await render(entry);
    return {
      ...entry,
      Content,
    };
  })
);
---

<div class="relative border-l-2 border-moss-200 ml-4 md:ml-8 pl-6 md:pl-8 py-2 flex flex-col gap-10 md:gap-12">
  {
    processedEntries.map(({ data, Content, id }) => (
      <div class="relative group" id={variant === 'full' ? id : undefined}>
        {/* Timeline Node dot */}
        <div class="absolute -left-[31px] md:-left-[39px] top-1.5 w-4 h-4 rounded-full border-2 border-moss-700 bg-beige-100 group-hover:bg-citrus-500 transition-colors duration-200" />
        
        <div class="flex flex-col md:flex-row md:items-start gap-4">
          <div class="flex-grow">
            <span class="inline-block px-2.5 py-0.5 rounded-full text-small font-bold bg-moss-200 text-moss-900 mb-2">
              {data.period}
            </span>
            <h3 class="text-h3 font-bold text-moss-900 leading-snug">
              {data.role}
            </h3>
            <p class="font-display text-base text-moss-700 mb-2">
              {data.org}
            </p>
            
            {variant === 'full' ? (
              <div class="prose prose-ink max-w-[68ch] mt-4 text-ink leading-relaxed">
                <Content />
              </div>
            ) : (
              <a 
                href={`/about#${id}`} 
                class="inline-flex items-center text-small font-bold text-moss-700 hover:text-moss-500 hover:underline gap-1 mt-2 focus:outline-none focus:ring-2 focus:ring-moss-900 focus:ring-offset-2 focus:ring-offset-beige-100 rounded"
              >
                Read full story
                <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 transition-transform group-hover:translate-x-1" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
              </a>
            )}
          </div>
          
          {data.logo && (
            <div class="flex-shrink-0 order-first md:order-last">
              <div class="w-12 h-12 rounded-lg bg-beige-50 border border-moss-200 overflow-hidden flex items-center justify-center p-2">
                <Image 
                  src={data.logo} 
                  alt={`${data.org} logo`} 
                  class="max-w-full max-h-full object-contain"
                />
              </div>
            </div>
          )}
        </div>
      </div>
    ))
  }
</div>
