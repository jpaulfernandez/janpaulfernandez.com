---
// ArticleLayout.astro
import BaseLayout from './BaseLayout.astro';
import JsonLd from '../components/JsonLd.astro';
import { Image } from 'astro:assets';
import paulImage from '../assets/paul.webp';
import { blogPosting, breadcrumbs } from '../lib/schema';
import type { ThoughtEntry } from '../lib/thoughts';

interface Props {
  post: ThoughtEntry;
  headings: { depth: number; slug: string; text: string }[];
  relatedPosts: ThoughtEntry[];
  prevPost: ThoughtEntry | null;
  nextPost: ThoughtEntry | null;
}

const { post, headings, relatedPosts, prevPost, nextPost } = Astro.props;
const { title, excerpt, publishedDate, updatedDate, type, stage, cover, topics } = post.data;

// Calculate word count and reading time
const wordCount = post.body ? post.body.split(/\s+/).filter(Boolean).length : 0;
const readingTime = Math.max(1, Math.ceil(wordCount / 200));

// Emojis for growth stages
const stageEmojis = {
  seedling: '🌱',
  budding: '🌿',
  evergreen: '🌳',
};

const stageEmoji = stage ? stageEmojis[stage as keyof typeof stageEmojis] || '' : '';

// Render published / updated date
const formatDate = (dateStr: string) => {
  return new Date(dateStr).toLocaleDateString('en-US', {
    year: 'numeric',
    month: 'long',
    day: 'numeric',
  });
};

// Filter H2s for TOC
const h2s = headings.filter((h) => h.depth === 2);
const showToc = h2s.length >= 2;

// Schemas
const blogPostSchema = blogPosting({
  title,
  excerpt,
  publishedDate,
  updatedDate,
  cover: cover ? (typeof cover === 'string' ? cover : cover.src) : undefined,
  topics,
  wordCount,
  type,
});

const breadcrumbsSchema = breadcrumbs([
  { name: 'Home', url: '/' },
  { name: 'Thoughts', url: '/thoughts' },
  { name: title, url: `/thoughts/${post.id}` },
]);

// OG image fallback to dynamically generated OG image endpoint
const ogImageUrl = cover ? (typeof cover === 'string' ? cover : cover.src) : `/og/${post.id}.png`;
---

<BaseLayout title={title} description={excerpt} ogImage={ogImageUrl} type="article">
  <JsonLd slot="head" data={[blogPostSchema, breadcrumbsSchema]} />

  <article class="max-w-[1440px] mx-auto px-6 py-12 md:py-16">
    <!-- Layout Container: 3-column grid ensures the main article content is 100% centered in the page, with TOC floating in the left margin! -->
    <div class="max-w-[1440px] mx-auto grid grid-cols-1 xl:grid-cols-[1fr_minmax(0,720px)_1fr] gap-8 xl:gap-12 items-start">
      <!-- Left Margin Column: Table of Contents -->
      <div class="hidden xl:flex justify-end w-full">
        {showToc && (
          <aside class="w-full max-w-[256px] sticky top-28 self-start group transition-opacity duration-300 opacity-60 hover:opacity-100">
            <nav aria-label="Table of contents" class="py-2">
              <h2 class="font-display text-xs uppercase tracking-widest text-moss-700 mb-3 group-hover:text-moss-900 transition-colors">
                Table of Contents
              </h2>
              <ul class="flex flex-col gap-2.5 text-small list-none pl-0 border-l border-moss-200/60 m-0">
                {h2s.map(h => (
                  <li>
                    <a
                      href={`#${h.slug}`}
                      class="toc-link no-underline text-moss-700/80 hover:text-alert-terracotta-600 hover:font-medium -ml-[1px] pl-4 block transition-all duration-200 leading-snug py-0.5"
                      data-slug={h.slug}
                    >
                      {h.text}
                    </a>
                  </li>
                ))}
              </ul>
            </nav>
          </aside>
        )}
      </div>

      <!-- Center Column: 100% centered main article content -->
      <div class="w-full max-w-[720px] mx-auto min-w-0">
        <!-- Header block inspired by screenshot -->
        <header class="mb-10 text-left fade-rise">
          <!-- Top Category & Stage Line -->
          <div class="flex flex-wrap items-center gap-2 text-xs font-display tracking-widest uppercase mb-4">
            <span class="text-alert-terracotta-600 font-bold">{type}</span>
            {stage && (
              <>
                <span class="text-moss-500">{stageEmoji || '🌿'}</span>
                <span class="text-moss-900">{stage}</span>
              </>
            )}
          </div>

          <!-- Title -->
          <h1 class="mb-4 leading-tight text-moss-900 font-display">{title}</h1>

          <!-- Subtitle / Excerpt -->
          {excerpt && (
            <p class="text-h3 font-body font-normal text-moss-700 leading-relaxed mb-6">
              {excerpt}
            </p>
          )}

          <!-- Horizontal rule separator -->
          <hr class="border-t border-moss-200/60 my-6" />

          <!-- Bottom Metadata Row (Topics left, Date right) -->
          <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-4 text-small text-moss-700 font-medium">
            <!-- Topics / Tags -->
            <div class="flex flex-wrap items-center gap-3">
              {topics && topics.length > 0 ? (
                topics.map(topic => (
                  <a
                    href={`/topics/${topic}`}
                    class="no-underline text-alert-terracotta-600 hover:text-dark-plum-900 hover:underline transition-colors font-semibold capitalize"
                  >
                    {topic}
                  </a>
                ))
              ) : (
                <span class="text-moss-500 capitalize">{type}</span>
              )}
            </div>

            <!-- Date & Reading Time -->
            <div class="flex items-center gap-2 text-xs sm:text-small text-moss-500 shrink-0">
              <span>Planted {formatDate(publishedDate)}</span>
              {updatedDate && (
                <span class="italic">(Updated {formatDate(updatedDate)})</span>
              )}
              <span>•</span>
              <span>{readingTime} min read</span>
            </div>
          </div>
        </header>

        <!-- Main body content rendered from slot -->
        <div class="prose max-w-none text-ink leading-relaxed fade-rise">
          <slot />
        </div>

        <hr class="border-t border-moss-200 my-12" />

        <!-- Author card -->
        <section class="bg-beige-50 border border-moss-200 rounded-lg p-6 flex flex-col sm:flex-row gap-5 items-center sm:items-start text-center sm:text-left mb-12">
          <Image
            src={paulImage}
            alt="Paul Fernandez"
            class="w-20 h-20 rounded-full object-cover border border-moss-200 shrink-0"
          />
          <div>
            <h3 class="font-display text-xs uppercase tracking-wider text-moss-900 mb-2">Written by Paul Fernandez</h3>
            <p class="text-small text-ink mb-4 leading-relaxed">
              Tech leader from the Philippines who has shipped under pressure (banking, election newsrooms, national digital education) now helping organizations digitally transform and adopt AI.
            </p>
            <div class="flex flex-wrap gap-4 justify-center sm:justify-start">
              <a href="/about" class="text-small font-bold no-underline text-moss-700 hover:text-moss-900 hover:underline">
                About Paul →
              </a>
              <a href="/work-with-me" class="text-small font-bold no-underline text-moss-700 hover:text-moss-900 hover:underline">
                Work with me →
              </a>
            </div>
          </div>
        </section>

        <!-- Prev/Next pagination -->
        {(prevPost || nextPost) && (
          <nav aria-label="Pagination" class="grid grid-cols-1 sm:grid-cols-2 gap-4 border-t border-moss-200 pt-8 mb-12">
            <div>
              {prevPost && (
                <a href={`/thoughts/${prevPost.id}`} class="flex flex-col gap-1 p-4 border border-moss-200 rounded-lg bg-beige-50 hover:bg-beige-50/50 no-underline text-left transition-colors h-full">
                  <span class="text-xs text-moss-500 font-semibold uppercase tracking-wider">← Previous</span>
                  <span class="text-small font-bold text-moss-900 line-clamp-2 leading-tight">{prevPost.data.title}</span>
                </a>
              )}
            </div>
            <div>
              {nextPost && (
                <a href={`/thoughts/${nextPost.id}`} class="flex flex-col gap-1 p-4 border border-moss-200 rounded-lg bg-beige-50 hover:bg-beige-50/50 no-underline text-right transition-colors h-full">
                  <span class="text-xs text-moss-500 font-semibold uppercase tracking-wider">Next →</span>
                  <span class="text-small font-bold text-moss-900 line-clamp-2 leading-tight">{nextPost.data.title}</span>
                </a>
              )}
            </div>
          </nav>
        )}

        <!-- Related thoughts -->
        {relatedPosts.length > 0 && (
          <section class="border-t border-moss-200 pt-10">
            <h3 class="font-display text-small uppercase tracking-wider text-moss-900 mb-6">Related thoughts</h3>
            <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
              {relatedPosts.map(post => (
                <a href={`/thoughts/${post.id}`} class="group flex flex-col p-5 border border-moss-200 rounded-lg bg-beige-50 hover:bg-beige-50/50 transition-colors no-underline">
                  <span class="text-xs font-semibold text-moss-500 uppercase tracking-widest mb-2 block">{post.data.type}</span>
                  <h4 class="font-display text-small text-moss-900 group-hover:text-moss-700 leading-snug mb-3">{post.data.title}</h4>
                  <p class="text-xs text-ink line-clamp-3 mb-0 leading-relaxed">{post.data.excerpt}</p>
                </a>
              ))}
            </div>
          </section>
        )}
      </div>

      <!-- Right Margin Column: Empty spacer to balance left column, keeping center column dead center -->
      <div class="hidden xl:block w-full"></div>
    </div>

    <!-- Mobile TOC Bottom Pill -->
    {showToc && (
      <div class="xl:hidden fixed bottom-6 left-4 right-4 z-40 flex justify-center pointer-events-none">
        <details id="mobile-toc-details" class="pointer-events-auto bg-moss-900 text-beige-50 rounded-full shadow-2xl border border-moss-700/60 max-w-md w-full overflow-hidden transition-all duration-300 group open:rounded-2xl">
          <summary class="flex items-center justify-between px-5 py-3 cursor-pointer select-none list-none [&::-webkit-details-marker]:hidden font-display text-xs tracking-widest uppercase text-beige-50 gap-3">
            <div class="flex items-center gap-2.5 truncate">
              <span class="text-citrus-500 shrink-0">📑</span>
              <span id="mobile-toc-current" class="truncate font-semibold">Table of Contents</span>
            </div>
            <svg class="w-4 h-4 shrink-0 transition-transform duration-200 group-open:rotate-180 text-moss-200" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
            </svg>
          </summary>
          <div class="max-h-[50vh] overflow-y-auto px-4 py-3 border-t border-moss-700/60 bg-moss-900/95 backdrop-blur-md">
            <div class="text-[11px] font-display uppercase tracking-widest text-moss-200/60 px-2 mb-2">
              Sections
            </div>
            <ul class="flex flex-col gap-1 list-none pl-0 m-0">
              {h2s.map(h => (
                <li>
                  <a
                    href={`#${h.slug}`}
                    class="mobile-toc-link block py-2 px-2.5 rounded-lg hover:bg-moss-700/60 text-beige-100 hover:text-beige-50 no-underline transition-colors text-small leading-snug font-body"
                    data-slug={h.slug}
                  >
                    {h.text}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        </details>
      </div>
    )}
  </article>

  {showToc && (
    <script is:inline>
      document.addEventListener('DOMContentLoaded', () => {
        // Close mobile TOC menu when a link is clicked
        const mobileDetails = document.getElementById('mobile-toc-details');
        const mobileLinks = document.querySelectorAll('.mobile-toc-link');
        mobileLinks.forEach(link => {
          link.addEventListener('click', () => {
            if (mobileDetails) mobileDetails.removeAttribute('open');
          });
        });

        // Track scroll position to update active TOC section on desktop and mobile pill
        const currentSpan = document.getElementById('mobile-toc-current');
        const tocLinks = document.querySelectorAll('.toc-link');
        const headings = Array.from(document.querySelectorAll('article h2[id]'));

        if (headings.length > 0 && ('IntersectionObserver' in window)) {
          const observer = new IntersectionObserver((entries) => {
            entries.forEach(entry => {
              if (entry.isIntersecting) {
                const slug = entry.target.id;
                const activeText = entry.target.textContent;
                if (currentSpan && activeText) {
                  currentSpan.textContent = activeText;
                }
                tocLinks.forEach(link => {
                  const isMatch = link.getAttribute('data-slug') === slug;
                  link.classList.toggle('text-alert-terracotta-600', isMatch);
                  link.classList.toggle('font-bold', isMatch);
                  link.classList.toggle('text-moss-700/80', !isMatch);
                  if (isMatch) {
                    link.style.borderLeft = '2px solid var(--color-alert-terracotta-600)';
                    link.style.marginLeft = '-2px';
                  } else {
                    link.style.borderLeft = 'none';
                    link.style.marginLeft = '0';
                  }
                });
                mobileLinks.forEach(link => {
                  const isMatch = link.getAttribute('data-slug') === slug;
                  link.classList.toggle('bg-moss-700/60', isMatch);
                  link.classList.toggle('text-citrus-500', isMatch);
                  link.classList.toggle('font-bold', isMatch);
                });
              }
            });
          }, { rootMargin: '-10% 0px -75% 0px', threshold: 0 });

          headings.forEach(h => observer.observe(h));
        }
      });
    </script>
  )}
</BaseLayout>
