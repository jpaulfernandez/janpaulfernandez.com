---
// index.astro (Gallery index — photobook list)
import BaseLayout from '../../layouts/BaseLayout.astro';
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';

const allItems = (await getCollection('gallery')).sort(
  (a, b) => new Date(b.data.publishedDate).getTime() - new Date(a.data.publishedDate).getTime()
);

// Derive unique tags from actual items
const allTags = Array.from(
  new Set(allItems.flatMap((item) => item.data.tags || []))
).sort();

const description = "Concert photography and visual stories by Jan Paul Fernandez. Browse photo collections from live music events and festivals.";
---

<BaseLayout title="Gallery" description={description}>
  <div class="max-w-[1140px] mx-auto px-6 py-12 md:py-16">
    <header class="max-w-[720px] mb-10">
      <h1 class="mb-4">Gallery</h1>
      <p class="text-body text-ink leading-relaxed">
        Live music, concert stages, and festival energy — captured through the lens.
      </p>
    </header>

    <!-- Filter toolbar -->
    <div class="mb-8 flex flex-col gap-4" role="group" aria-label="Filter gallery by tag">
      <div class="flex flex-wrap items-center justify-between gap-4">
        {allTags.length > 0 && (
          <div class="flex flex-wrap gap-2" data-filter-group="tag">
            <button class="filter-chip cursor-pointer rounded-full px-3.5 py-1.5 text-small font-bold text-moss-700 border border-moss-200 hover:border-moss-500 aria-pressed:bg-moss-900 aria-pressed:text-beige-50 aria-pressed:border-moss-900 transition-colors focus:outline-none focus-visible:ring-2 focus-visible:ring-moss-500" aria-pressed="true" data-value="all">All</button>
            {allTags.map((tag) => (
              <button class="filter-chip cursor-pointer rounded-full px-3.5 py-1.5 text-small font-bold text-moss-700 border border-moss-200 hover:border-moss-500 aria-pressed:bg-moss-900 aria-pressed:text-beige-50 aria-pressed:border-moss-900 transition-colors focus:outline-none focus-visible:ring-2 focus-visible:ring-moss-500" aria-pressed="false" data-value={tag}>
                #{tag}
              </button>
            ))}
          </div>
        )}

        <span id="gallery-counter" class="text-small text-moss-700 font-bold ml-auto">
          {allItems.length} {allItems.length === 1 ? 'collection' : 'collections'}
        </span>
        <div id="filter-aria-announcer" aria-live="polite" class="sr-only">
          Showing {allItems.length} collections
        </div>
      </div>
    </div>

    <!-- Gallery Grid — cinematic photobook cards -->
    <div id="gallery-grid" class="grid grid-cols-1 md:grid-cols-2 gap-8">
      {allItems.map((item) => {
        const photoCount = (item.data.photos?.length || 0) + (item.data.cover ? 1 : 0);
        const dateFormatted = new Date(item.data.publishedDate).toLocaleDateString('en-US', {
          year: 'numeric',
          month: 'long',
        });

        return (
          <a
            href={`/gallery/${item.id}`}
            class="gallery-card group relative flex flex-col rounded-[2rem] overflow-hidden border border-moss-200/60 bg-beige-50 transition-all duration-500 hover:-translate-y-2 hover:shadow-2xl focus:outline-none focus:ring-2 focus:ring-citrus-500 no-underline text-ink"
            data-tags={item.data.tags?.join(',')}
          >
            {/* Cover Image — cinematic 16:10 */}
            <div class="relative aspect-[16/10] w-full overflow-hidden bg-moss-900/5">
              {item.data.cover ? (
                <Image
                  src={item.data.cover}
                  alt={item.data.title}
                  class="w-full h-full object-cover transition-transform duration-700 ease-out group-hover:scale-110"
                  width={800}
                  height={500}
                />
              ) : (
                <div class="w-full h-full flex items-center justify-center bg-gradient-to-br from-moss-700 to-moss-900 text-beige-100 font-display text-h3">
                  {item.data.title}
                </div>
              )}

              {/* Dark gradient overlay for text legibility */}
              <div class="absolute inset-0 bg-gradient-to-t from-black/70 via-black/20 to-transparent opacity-60 group-hover:opacity-80 transition-opacity duration-500"></div>

              {/* Photo count badge */}
              {photoCount > 1 && (
                <div class="absolute top-4 right-4 bg-black/40 backdrop-blur-md rounded-full px-3 py-1.5 text-[11px] font-bold text-beige-100 border border-white/10 flex items-center gap-1.5">
                  <svg class="w-3 h-3" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                    <rect width="18" height="18" x="3" y="3" rx="2" ry="2"/>
                    <circle cx="8.5" cy="8.5" r="1.5"/>
                    <polyline points="21 15 16 10 5 21"/>
                  </svg>
                  {photoCount}
                </div>
              )}

              {/* Title overlay at bottom of image */}
              <div class="absolute bottom-0 left-0 right-0 p-6 md:p-8">
                <time datetime={item.data.publishedDate} class="block text-small text-beige-100/70 mb-2 font-bold tracking-wide uppercase">
                  {dateFormatted}
                </time>
                <h2 class="font-display text-h3 md:text-h2 text-beige-50 m-0 leading-tight group-hover:text-citrus-300 transition-colors duration-300">
                  {item.data.title}
                </h2>
              </div>
            </div>

            {/* Content bar */}
            <div class="p-5 md:p-6 flex items-center justify-between gap-4 border-t border-moss-200/40">
              {/* Tags */}
              <div class="flex flex-wrap gap-1.5 min-w-0">
                {item.data.tags && item.data.tags.slice(0, 4).map((tag) => (
                  <span class="text-[11px] font-bold text-moss-500 bg-moss-200/40 px-2 py-0.5 rounded-full whitespace-nowrap">
                    #{tag}
                  </span>
                ))}
              </div>

              {/* Arrow CTA */}
              <div class="shrink-0 w-8 h-8 rounded-full bg-moss-900 text-beige-50 flex items-center justify-center group-hover:bg-citrus-500 group-hover:text-moss-900 transition-colors duration-300">
                <svg class="w-4 h-4 transition-transform duration-300 group-hover:translate-x-0.5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
                </svg>
              </div>
            </div>
          </a>
        );
      })}
    </div>

    <!-- Empty State -->
    <div id="empty-state" class="hidden text-center py-16 border border-dashed border-moss-200 rounded-xl bg-beige-50">
      <p class="font-display text-moss-900 mb-2">No gallery collections match your filter.</p>
      <p class="text-small text-moss-500">Try selecting "All" to reset filters.</p>
    </div>
  </div>
</BaseLayout>

<!-- Native client-side DOM filter script (Progressive Enhancement) -->
<script>
  const chips = document.querySelectorAll('.filter-chip');
  const cards = document.querySelectorAll('.gallery-card') as NodeListOf<HTMLElement>;
  const counter = document.getElementById('gallery-counter');
  const announcer = document.getElementById('filter-aria-announcer');
  const emptyState = document.getElementById('empty-state');

  let activeTag = 'all';

  chips.forEach((chip) => {
    chip.addEventListener('click', () => {
      const parentGroup = chip.closest('[data-filter-group]') as HTMLElement | null;
      if (!parentGroup) return;

      parentGroup.querySelectorAll('.filter-chip').forEach((c) => c.setAttribute('aria-pressed', 'false'));
      chip.setAttribute('aria-pressed', 'true');
      activeTag = chip.getAttribute('data-value') || 'all';

      let visibleCount = 0;
      cards.forEach((card) => {
        const cardTags = card.getAttribute('data-tags')?.split(',') || [];
        const matchesTag = activeTag === 'all' || cardTags.includes(activeTag);

        if (matchesTag) {
          card.classList.remove('hidden');
          visibleCount++;
        } else {
          card.classList.add('hidden');
        }
      });

      const resultText = `${visibleCount} collection${visibleCount === 1 ? '' : 's'}`;
      if (counter) counter.textContent = resultText;
      if (announcer) announcer.textContent = `Showing ${resultText}`;

      if (visibleCount === 0) {
        emptyState?.classList.remove('hidden');
      } else {
        emptyState?.classList.add('hidden');
      }
    });
  });
</script>
