---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import JsonLd from '../components/JsonLd.astro';
import { profilePage, breadcrumbs } from '../lib/schema';

const nowEntries = await getCollection('now');

// Sort reverse-chronologically (newest first)
const sortedNow = [...nowEntries].sort((a, b) => b.data.date.localeCompare(a.data.date));

function parseDateSafe(dateStr: string | Date) {
  const str = typeof dateStr === 'string' ? dateStr : dateStr.toISOString().slice(0, 10);
  return new Date(`${str}T12:00:00`);
}

const latestDate = sortedNow[0]?.data.date;
const formattedLastUpdated = latestDate
  ? parseDateSafe(latestDate).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })
  : 'July 5, 2026';

const processedNow = await Promise.all(
  sortedNow.map(async (entry) => {
    const { Content } = await render(entry);
    const dateObj = parseDateSafe(entry.data.date);
    const exactDateFormatted = dateObj.toLocaleDateString('en-US', {
      month: 'long',
      day: 'numeric',
      year: 'numeric',
    });
    const monthYear = dateObj.toLocaleDateString('en-US', {
      month: 'long',
      year: 'numeric',
    });
    return { ...entry, Content, exactDateFormatted, monthYear };
  })
);

const groupedNow: { monthYear: string; items: typeof processedNow }[] = [];
for (const item of processedNow) {
  let group = groupedNow.find((g) => g.monthYear === item.monthYear);
  if (!group) {
    group = { monthYear: item.monthYear, items: [] };
    groupedNow.push(group);
  }
  group.items.push(item);
}

// ProfilePage dateModified reflects the latest Now entry date for freshness signals
const seoData = [
  profilePage(latestDate ? new Date(latestDate).toISOString() : undefined),
  breadcrumbs([
    { name: 'Home', url: '/' },
    { name: 'Now', url: '/now' },
  ]),
];
---

<BaseLayout
  title="Now"
  description="What Paul Fernandez is focused on, building, and learning right now."
>
  <JsonLd data={seoData} slot="head" />

  <article class="py-16 md:py-24 max-w-[1140px] mx-auto px-6 fade-rise">
    {/* Page Title */}
    <div class="mb-8">
      <span class="text-small font-bold uppercase tracking-wider text-moss-700">Current Status</span>
      <h1 class="text-h1 text-moss-900 mt-1">What I'm doing now</h1>
      <p class="text-small text-moss-700 font-bold mt-2">
        Last updated: {formattedLastUpdated}
      </p>
    </div>

    {/* Intro Explaining the Page */}
    <div class="prose prose-ink max-w-[68ch] text-ink leading-relaxed flex flex-col gap-4 mb-16 border-b border-moss-200 pb-8">
      <p class="text-body font-normal m-0">
        This is a now page — a public dashboard of what I'm focused on these days: current priorities, projects, and what I'm learning.
      </p>
      <p class="text-body font-normal m-0">
        Maybe it's a little bit of oversharing. But I wanted a public journal of sorts — a record of where my head is at right now, kept honest by the fact that anyone can read it. If you're wondering what I'm up to, this is the place.
      </p>
    </div>

    {/* Now Timeline */}
    <div class="relative border-l-2 border-moss-200 ml-4 md:ml-8 pl-6 md:pl-8 py-2 flex flex-col gap-14 md:gap-16">
      {
        groupedNow.map(({ monthYear, items }) => (
          <div class="relative group">
            {/* Timeline Node dot */}
            <div class="absolute -left-[31px] md:-left-[39px] top-2 md:top-3 w-4 h-4 rounded-full border-2 border-moss-700 bg-beige-100 group-hover:bg-citrus-500 transition-colors duration-200" />
            
            <div class="flex flex-col gap-8">
              <h2 class="text-h2 font-display text-moss-900 m-0 leading-none">
                {monthYear}
              </h2>
              
              <div class="flex flex-col gap-10">
                {items.map(({ data, Content, id, exactDateFormatted }) => {
                  const displayTitle = data.title || data.slug || id;
                  return (
                    <div class="flex flex-col gap-3">
                      <div class="flex flex-col gap-1">
                        <h3 class="text-h3 font-bold text-moss-900 leading-snug m-0">
                          {displayTitle}
                        </h3>
                        <time class="text-small font-bold text-moss-700 font-body" datetime={data.date}>
                          {exactDateFormatted}
                        </time>
                      </div>
                      
                      <div class="prose prose-ink max-w-[68ch] text-ink leading-relaxed text-body">
                        <Content />
                      </div>
                      
                      {data.link && (
                        <a 
                          href={data.link} 
                          target="_blank" 
                          rel="noopener noreferrer" 
                          class="inline-flex items-center text-small font-bold text-moss-700 hover:text-moss-500 hover:underline gap-1 focus:outline-none focus:ring-2 focus:ring-moss-900 rounded self-start"
                        >
                          Reference link
                          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6M15 3h6v6M10 14L21 3"/></svg>
                        </a>
                      )}
                    </div>
                  );
                })}
              </div>
            </div>
          </div>
        ))
      }

      {/* End of Timeline Node */}
      <div class="relative group">
        {/* Timeline Node dot */}
        <div class="absolute -left-[31px] md:-left-[39px] top-1.5 w-4 h-4 rounded-full border-2 border-moss-700 bg-beige-100 group-hover:bg-citrus-500 transition-colors duration-200 flex items-center justify-center">
          <div class="w-1.5 h-1.5 rounded-full bg-moss-700 group-hover:bg-beige-100 transition-colors duration-200"></div>
        </div>
        
        <div class="flex flex-col gap-2">
          <span class="inline-block self-start px-2.5 py-0.5 rounded-full text-small font-bold bg-moss-200 text-moss-900">
            End of timeline
          </span>
          
          <p class="prose prose-ink max-w-[68ch] text-moss-700 text-body italic m-0">
            You've reached the end of the timeline! Nothing here anymore... go touch some grass, build something cool, or <a href="/work-with-me#contact" class="text-moss-900 font-bold underline decoration-moss-300 hover:decoration-moss-900 transition-colors">invite me for coffee</a>.
          </p>
        </div>
      </div>
    </div>
  </article>
</BaseLayout>
