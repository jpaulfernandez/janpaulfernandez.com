---
// [topic].astro (Topic archive pages)
import BaseLayout from '../../layouts/BaseLayout.astro';
import PostListItem from '../../components/PostListItem.astro';
import { getPublishedThoughts } from '../../lib/thoughts';

export async function getStaticPaths() {
  const allPosts = await getPublishedThoughts();
  
  // Extract all unique topics
  const topics = Array.from(
    new Set(allPosts.flatMap((post) => post.data.topics || []))
  );

  return topics.map((topic) => {
    const matchingPosts = allPosts.filter((post) =>
      post.data.topics?.includes(topic)
    );
    return {
      params: { topic },
      props: { posts: matchingPosts, topic },
    };
  });
}

const { posts, topic } = Astro.props;
const description = `Archive of thoughts published by Paul Fernandez on the topic of ${topic}.`;
---

<BaseLayout title={`Thoughts on ${topic}`} description={description}>
  <div class="max-w-[1140px] mx-auto px-6 py-12 md:py-16">
    <header class="max-w-[720px] mb-12">
      <div class="mb-4">
        <a href="/thoughts" class="text-xs uppercase tracking-wider font-semibold no-underline text-moss-700 hover:text-moss-900 hover:underline">
          ← Back to all thoughts
        </a>
      </div>
      <h1 class="mb-4 capitalize">Thoughts on {topic}</h1>
      <p class="text-body text-ink leading-relaxed">
        Showing {posts.length} published thought{posts.length === 1 ? '' : 's'} tagged with #{topic}.
      </p>
    </header>

    <!-- Posts list -->
    <div class="divide-y divide-moss-200 border-t border-moss-200">
      {posts.map((post) => {
        const wordCount = post.body ? post.body.split(/\s+/).filter(Boolean).length : 0;
        const readingTime = Math.max(1, Math.ceil(wordCount / 200));

        return (
          <PostListItem
            title={post.data.title}
            type={post.data.type}
            topics={post.data.topics || []}
            date={post.data.publishedDate}
            excerpt={post.data.excerpt}
            url={`/thoughts/${post.id}`}
            readingTime={readingTime}
            stage={post.data.stage}
            cover={post.data.cover}
          />
        );
      })}
    </div>
  </div>
</BaseLayout>
